        "jsCode": "const raw = $input.item.json.choices[0].message.content; const parsed = JSON.parse(raw); return { category: parsed.category, reason: parsed.reason, originalSubject: $('Gmail Trigger').item.json.snippet, threadId: $('Gmail Trigger').item.json.threadId, messageId: $('Gmail Trigger').item.json.id };"
      },
